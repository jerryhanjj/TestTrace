{
  "name": "testtrace",
  "displayName": "TestTrace",
  "description": "Generate AI test trace labels from gtest and CUnit tests.",
  "version": "0.0.1",
  "publisher": "testtrace-local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:testTrace.generateFromCurrentFile",
    "onCommand:testTrace.generateFromSelection",
    "onCommand:testTrace.reviewLastParseResult"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "testTrace.generateFromCurrentFile",
        "title": "Generate Labels from Current File",
        "category": "TestTrace"
      },
      {
        "command": "testTrace.generateFromSelection",
        "title": "Generate Labels from Selection",
        "category": "TestTrace"
      },
      {
        "command": "testTrace.reviewLastParseResult",
        "title": "Review Last Parse Result",
        "category": "TestTrace"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "testTrace.generateFromCurrentFile",
          "when": "editorTextFocus && (resourceLangId == c || resourceLangId == cpp)",
          "group": "navigation@testTrace"
        },
        {
          "command": "testTrace.generateFromSelection",
          "when": "editorTextFocus && editorHasSelection && (resourceLangId == c || resourceLangId == cpp)",
          "group": "navigation@testTrace"
        }
      ],
      "commandPalette": [
        {
          "command": "testTrace.generateFromCurrentFile",
          "when": "editorTextFocus"
        },
        {
          "command": "testTrace.generateFromSelection",
          "when": "editorTextFocus && editorHasSelection"
        },
        {
          "command": "testTrace.reviewLastParseResult"
        }
      ]
    },
    "configuration": {
      "title": "TestTrace",
      "properties": {
        "testTrace.serviceBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:43125",
          "description": "Base URL of the standalone TestTrace backend service."
        }
      }
    }
  },
  "scripts": {
    "compile": "npm run check-types && node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "check-types": "tsc --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test .test-dist/tests/*.test.js",
    "package:vsix": "vsce package --allow-missing-repository --skip-license",
    "server:build": "npm --prefix server run build",
    "server:start": "npm --prefix server run start"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.2",
    "@types/node": "^22.13.4",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.25.5",
    "typescript": "^5.8.3"
  }
}